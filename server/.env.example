# ═══════════════════════════════════════════════════════════════════════════
# Required to run `npm start` without errors:
#   • One of: RPC_URL  |  INFURA_PROJECT_ID  |  legacy ALCHEMY_API_KEY
#     (JSON-RPC to Base Sepolia, or Anvil: RPC_URL=http://127.0.0.1:8545)
#   • server/addresses.json (or ADDRESSES_FILE) with deployed contract addresses
#
# Optional but needed for on-chain writes (delegate, execute, revoke, agent register):
#   • PRIVATE_KEY — funded wallet on the same chain as RPC
#
# If PRIVATE_KEY is empty, the server still starts (read-only contracts + Biscuit).
# ═══════════════════════════════════════════════════════════════════════════
#
# ── Suggested order (secrets) ──
# 1) Pimlico (account abstraction / bundler — if you use it in routes)
PIMLICO_API_KEY=

# 2) Neon PostgreSQL (optional — enables persistence / audit table)
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
DATABASE_URL=

# Base Sepolia — pick ONE primary RPC strategy (Infura recommended for log-heavy calls):
#
# A) Full URL (any provider), e.g. Infura:
# RPC_URL=https://base-sepolia.infura.io/v3/YOUR_PROJECT_ID
#
# B) Infura project id only (HTTPS + WSS URLs are derived automatically):
INFURA_PROJECT_ID=
# (alias) INFURA_API_KEY=
#
# C) Legacy Alchemy (still supported):
# ALCHEMY_API_KEY=
#
# Optional explicit WebSocket (otherwise derived for Infura / Alchemy):
# WS_RPC_URL=wss://base-sepolia.infura.io/ws/v3/YOUR_PROJECT_ID
#
# Local Anvil:
# RPC_URL=http://127.0.0.1:8545

# Hex private key (no 0x prefix is ok) — deployer / agent operator wallet
PRIVATE_KEY=

# Optional: alternate addresses file under server/
# ADDRESSES_FILE=addresses.local-anvil.json   # local Anvil (matches forge deploy to 127.0.0.1:8545)
# ADDRESSES_FILE=addresses.base-sepolia.json # same contract set as addresses.json (Base Sepolia); keep both in sync after deploy

# Optional: override JSON addresses (Base Sepolia deploy / CI)
# DCT_REGISTRY_ADDRESS=
# DCT_ENFORCER_ADDRESS=
# NOTARY_ATTESTATION_VERIFIER_ADDRESS=
# ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e

# Must match NotaryAttestationVerifier.notarySigner on deployment — used to sign TLS attestations
# (same as deployer key if you deployed with default notary)
NOTARY_PRIVATE_KEY=

# First block to scan for ERC-8004 Registered events (official registry only)
# ERC8004_EVENTS_FROM_BLOCK=0

# eth_getLogs block window per request (Infura Free tier max is 10; PAYG / other RPCs can raise)
# DCT_ETH_GETLOGS_CHUNK_BLOCKS=10

# First block when loading DCTEnforcer ActionValidated/Rejected for trust scores (set near deploy to reduce scans)
# DCT_ENFORCER_FROM_BLOCK=0

# Optional: override canonical Base Sepolia ERC-8004 registry when deploying
# ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e

# Optional: MetaMask DelegationManager (ERC-7710) on your chain
# DELEGATION_MANAGER_ADDRESS=
# DCT_CAVEAT_ENFORCER_ADDRESS=

# Optional: smart account owner for POST /api/aa/execute-scope (defaults to PRIVATE_KEY)
# AA_OWNER_PRIVATE_KEY=

# TLSNotary — POST /prove HTTP service (see server/scripts/tlsn-dev-prover.mjs → npm run tlsn-prover)
# Notary (MPC) is separate: docker compose -f docker-compose.tlsn.yml up -d  → :7047
# TLSN_PROVER_URL=http://127.0.0.1:8090
# TLSN_NOTARY_URL=http://127.0.0.1:7047

PORT=3000
