# Copy to client/.env (gitignored). No chain API keys here — the browser talks to your DCT server.

# Backend API (must match where `cd server && npm start` listens)
VITE_API_URL=http://localhost:3000

# Block explorer links in demos (Base Sepolia)
VITE_BASESCAN_URL=https://sepolia.basescan.org

# Live Demo phase 5: HTTPS URL proved via TLSNotary for tool web_fetch (must stay compatible with on-chain toolHash)
# VITE_TLSN_DEMO_URL=https://api.github.com/zen

# /tlsn Extension mode: verifier origin (defaults to https://demo.tlsnotary.org if unset). Use http://127.0.0.1:7047 when running tlsn-extension packages/verifier locally.
# VITE_TLSN_VERIFIER_URL=https://demo.tlsnotary.org

# ── Layer console (/layer) — optional overrides for "Autofill demo" (bundled defaults in src/lib/layerDemoDefaults.js)
# Use per-tunnel URL + token, OR set VITE_LAYER_SHARED_* once if all three share the same host/token.
# VITE_LAYER_ORCH_URL=https://….ngrok-free.dev
# VITE_LAYER_ORCH_BEARER=
# VITE_LAYER_RESEARCH_URL=
# VITE_LAYER_RESEARCH_BEARER=
# VITE_LAYER_PAYMENT_URL=
# VITE_LAYER_PAYMENT_BEARER=
# VITE_LAYER_SHARED_URL=
# VITE_LAYER_SHARED_BEARER=
# VITE_LAYER_MODEL=openclaw/main

# Layer: BTC + TLS + OpenClaw demo — HTTPS JSON URL for TLSNotary (default: CoinGecko BTC/USD)
# VITE_BTC_TLS_DEMO_URL=https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd

# Register & delegate on-chain: browser must wait for POST /api/layer/apply (many txs + gaps). Default 600000 ms (10 min).
# VITE_LAYER_APPLY_TIMEOUT_MS=600000
