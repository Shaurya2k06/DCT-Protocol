# Copy to client/.env (gitignored). No chain API keys here — the browser talks to your DCT server.

# Backend API (must match where `cd server && npm start` listens)
VITE_API_URL=http://localhost:3000

# Block explorer links in demos (Base Sepolia)
VITE_BASESCAN_URL=https://sepolia.basescan.org

